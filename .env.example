# ─── Environment ──────────────────────────────────────────────────────────────
NODE_ENV=production

# ─── Database ─────────────────────────────────────────────────────────────────
# Path to the SQLite database file (relative to project root or absolute)
DATABASE_PATH=data/cve_scraper.db

# ─── Scraping ─────────────────────────────────────────────────────────────────
MAX_CONCURRENT_REQUESTS=3
DELAY_BETWEEN_REQUESTS=2000
RETRY_ATTEMPTS=5

# Gentle mode: slower scraping to reduce API load.
# When enabled, uses GENTLE_DELAY_MS and disables parallel processing.
GENTLE_MODE=false
GENTLE_DELAY_MS=5000
GENTLE_HITS_PER_PAGE=10

# When true, uses technology-filter-based parallel scraping for better coverage.
# Automatically disabled when GENTLE_MODE=true.
USE_COMPREHENSIVE_SCRAPING=false

# ─── Scheduling ───────────────────────────────────────────────────────────────
# Cron expression for automatic scraping (leave empty to disable).
# Examples:
#   "0 */6 * * *"  — every 6 hours
#   "0 2 * * *"    — every day at 02:00
#   "0 */12 * * *" — every 12 hours
SCRAPER_CRON=

# Minimum hours between scrape runs (hard lower bound: 1 hour).
# Even if the cron fires more frequently, executions will be skipped
# unless at least MIN_INTERVAL_HOURS have passed since the last run.
MIN_INTERVAL_HOURS=1

# When true, triggers a scrape immediately when the API server starts.
SCRAPE_ON_START=false

# ─── Output / Checkpoints ─────────────────────────────────────────────────────
SAVE_CHECKPOINTS=true
CHECKPOINT_INTERVAL=100

# ─── API Server ───────────────────────────────────────────────────────────────
API_PORT=3000
API_HOST=0.0.0.0

# ─── Logging ──────────────────────────────────────────────────────────────────
# Logs are written to stdout/stderr (Docker-managed). No filesystem log file.
LOG_LEVEL=info

# ─── Target ───────────────────────────────────────────────────────────────────
TARGET_URL=https://www.wiz.io/vulnerability-database/cve/search

# ─── User-agent rotation ──────────────────────────────────────────────────────
# Comma-separated list of user-agent strings.  One is picked at random per
# outbound HTTP request.  Falls back to USER_AGENT (single) or built-in list.
USER_AGENTS=<comma-separated list of user-agent strings>
