{
  "name": "wiz-cve-scraper",
  "version": "1.0.0",
  "description": "A robust Node.js tool to extract CVE data from the Wiz vulnerability database using their Algolia API",
  "main": "src/app.js",
  "scripts": {
    "start": "node src/app.js",
    "dev": "node --inspect src/app.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint src/",
    "scrape": "node src/scraper.js",
    "api": "node src/api.js"
  },
  "keywords": [
    "web-scraping",
    "cve",
    "vulnerability",
    "security",
    "wiz"
  ],
  "author": "CVE Scraper Team",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.13.6",
    "better-sqlite3": "^12.8.0",
    "commander": "^14.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "fs-extra": "^11.3.4",
    "helmet": "^8.1.0",
    "joi": "^18.0.2",
    "node-cron": "^4.2.1",
    "p-limit": "^7.3.0",
    "progress": "^2.0.3",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.1.0",
    "eslint-plugin-n": "^17.24.0",
    "eslint-plugin-promise": "^7.2.1",
    "globals": "^17.4.0",
    "jest": "^30.3.0",
    "supertest": "^7.2.2"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/maxysoft/wiz-cves.git"
  },
  "bugs": {
